# AI Extraction Integration for train.ts
# Apply these changes to enable AI-powered fact extraction

## Step 1: Add imports at top of train.ts

```typescript
// ADD after existing imports
import { extractFactsWithAI } from '../../brain/ai-extractor.js';
```

## Step 2: Replace extractFacts call (around line 130-140)

**FIND this code:**
```typescript
const facts = extractFacts(textToTrain, source);

logger.info(
  { factCount: facts.length, textLength: textToTrain.length },
  "extractFacts returned"
);

if (facts.length === 0) {
  res.status(400).json({ error: "No learnable content found in text" });
  return;
}

logger.info({ firstFact: facts[0] }, "First extracted fact");
```

**REPLACE with:**
```typescript
// Use AI-powered extraction for PDFs and large documents
const useAI = source.includes('pdf') || source.includes('docx') || textToTrain.length > 50000;

let facts: string[];
let extractionMethod = 'regex';

if (useAI) {
  try {
    logger.info({ source, textLength: textToTrain.length }, "Using AI extraction");
    
    const extraction = await extractFactsWithAI(textToTrain, source.includes('pdf') ? 'pdf' : 'text', {
      maxFacts: 50,
      minConfidence: 0.6,
      model: 'claude-sonnet-4-20250514',
    });
    
    facts = extraction.facts.map(f => f.content);
    extractionMethod = extraction.model;
    
    logger.info(
      { 
        factCount: facts.length, 
        model: extraction.model,
        tokenCount: extraction.tokenCount,
        summary: extraction.summary?.substring(0, 100)
      },
      "AI extraction completed"
    );
    
    if (extraction.unknown_terms?.length) {
      logger.info(
        { terms: extraction.unknown_terms.slice(0, 10) },
        "Unknown technical terms found"
      );
    }
  } catch (error) {
    logger.error({ err: error }, "AI extraction failed, falling back to regex");
    facts = extractFacts(textToTrain, source);
    extractionMethod = 'regex-fallback';
  }
} else {
  facts = extractFacts(textToTrain, source);
  extractionMethod = 'regex';
}

logger.info(
  { factCount: facts.length, textLength: textToTrain.length, method: extractionMethod },
  "extractFacts returned"
);

if (facts.length === 0) {
  res.status(400).json({ error: "No learnable content found in text" });
  return;
}

logger.info({ firstFact: facts[0], method: extractionMethod }, "First extracted fact");
```

