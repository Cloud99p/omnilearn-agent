# OmniLearn Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# CORE REQUIREMENTS
# =============================================================================

DATABASE_URL=postgresql://user:password@localhost:5432/omnilearn
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# =============================================================================
# AI/LLM PROVIDERS
# =============================================================================

# FreeLLM unified API (Groq, Gemini, Mistral, Cerebras)
FREELLM_API_KEY=your_freellm_api_key

# Optional: Enable hybrid mode (LLM fallback)
USE_LLM_FALLBACK=true
LLM_FALLBACK_RATE=0.3

# =============================================================================
# CANTON NETWORK (NEW - RWA Integration)
# =============================================================================

# Canton Network RPC endpoint
CANTON_RPC_URL=https://rpc.canton.network

# API key for authenticated access (optional for devnet)
CANTON_API_KEY=your_canton_api_key

# DAML ledger URL (optional)
DAML_LEDGER_URL=https://ledger.daml.com

# Privacy domain ID (optional)
CANTON_DOMAIN_ID=your_domain_id

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================

# GitHub OAuth token (for repo features)
GITHUB_TOKEN=ghp_your_github_token

# Port (default: 3000)
PORT=3000

# =============================================================================
# NOT REQUIRED - Existing OmniLearn features continue to work
# =============================================================================

# All existing environment variables remain unchanged
# FreeLLM, Clerk, database, etc. all work exactly as before
# Canton is an ADD-ON, not a replacement
