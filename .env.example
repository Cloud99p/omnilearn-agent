# Database (use Replit DB, Supabase, Railway, or Neon)
DATABASE_URL=postgresql://user:password@localhost:5432/omnilearn

# Clerk Authentication (https://clerk.com)
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Anthropic API (https://console.anthropic.com)
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: Custom base URL (defaults to https://api.anthropic.com)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Replit AI Integration (alternative - if using Replit)
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=xxx
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=xxx

# GitHub OAuth (optional, for repo features)
GITHUB_TOKEN=ghp_xxx

# Server Configuration (optional)
PORT=3000
BASE_PATH=/

# Ghost Network (optional)
GHOST_SECRET=your-secret-key-here

# FreeLLM Hybrid Mode (optional)
# Week 1: ALWAYS_USE_LLM=true (100% FreeLLM while training)
# After cron reminder (May 30): change to false and set LLM_FALLBACK_RATE for gradual reduction
ALWAYS_USE_LLM=true
LLM_FALLBACK_RATE=0.7  # Use after week 1: 70% LLM, then reduce weekly
FREELLM_API_URL=http://localhost:3001/v1
FREELLM_API_KEY=your-freellm-api-key

# API Server URL (Railway deployment)
VITE_API_URL=https://workspaceapi-server-production-29ee.up.railway.app/api

# Sentry Error Tracking (https://sentry.io)
# Free tier: 10K errors/month, unlimited users
# Create account at https://sentry.io → New Project → Node.js
# Backend (Railway):
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=1.0.0  # or use git commit SHA
# Frontend (Vercel):
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_RELEASE=1.0.0  # or use git commit SHA
